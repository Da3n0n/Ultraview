    "activityBar.dropBorder": "#0000003e",
    "activityBar.inactiveForeground": "#0000003e",
    "activityBarBadge.background": "#0000003e",
    "badge.background": "#0000003e",
    "breadcrumbPicker.background": "#0000003e",
    "button.background": "#0000003e",
    "button.border": "#0000003e",
    "button.hoverBackground": "#0000003e",
    "button.secondaryBackground": "#0000003e",
    "button.secondaryHoverBackground": "#0000003e",
    "checkbox.background": "#0000003e",
    "checkbox.border": "#0000003e",
    "checkbox.selectBackground": "#0000003e",
    "checkbox.selectBorder": "#0000003e",
    "dropdown.background": "#0000003e",
    "dropdown.border": "#0000003e",
    "dropdown.listBackground": "#0000003e",
    "editor.background": "#0000003e",
    "editor.findMatchBackground": "#0000003e",
    "editor.findMatchHighlightBackground": "#0000003e",
    "editor.foldBackground": "#0000003e",
    "editor.inactiveSelectionBackground": "#0000003e",
    "editor.lineHighlightBackground": "#0000003e",
    "editor.lineHighlightBorder": "#0000003e",
    "editor.selectionBackground": "#0000003e",
    "editor.selectionHighlightBackground": "#0000003e",
    "editor.wordHighlightBackground": "#0000003e",
    "editorBracketMatch.background": "#0000003e",
    "editorBracketMatch.border": "#0000003e",
    "editorGroup.border": "#0000003e",
    "editorGroupHeader.tabsBackground": "#0000003e",
    "editorGroupHeader.tabsBorder": "#0000003e",
    "editorHoverWidget.background": "#0000003e",
    "editorInlayHint.background": "#0000003e",
    "editorInlayHint.typeBackground": "#0000003e",
    "editorLightBulb.foreground": "#0000003e",
    "editorLightBulbAutoFix.foreground": "#0000003e",
    "editorLineNumber.activeForeground": "#0000003e",
    "editorLineNumber.dimmedForeground": "#0000003e",
    "editorLineNumber.foreground": "#0000003e",
    "editorOverviewRuler.border": "#0000003e",
    "editorSuggestWidget.border": "#0000003e",
    "editorSuggestWidget.focusHighlightForeground": "#0000003e",
    "editorSuggestWidget.foreground": "#0000003e",
    "editorSuggestWidget.highlightForeground": "#0000003e",
    "editorSuggestWidget.selectedBackground": "#0000003e",
    "editorSuggestWidget.selectedForeground": "#0000003e",
    "editorSuggestWidget.selectedIconForeground": "#0000003e",
    "editorSuggestWidgetStatus.foreground": "#0000003e",
    "editorWidget.background": "#0000003e",
    "editorWidget.border": "#0000003e",
    "editorWidget.resizeBorder": "#0000003e",
    "extensionButton.background": "#0000003e",
    "extensionButton.hoverBackground": "#0000003e",
    "extensionButton.prominentBackground": "#0000003e",
    "extensionButton.prominentHoverBackground": "#0000003e",
    "extensionButton.separator": "#0000003e",
    "extensionIcon.preReleaseForeground": "#0000003e",
    "extensionIcon.sponsorForeground": "#0000003e",
    "extensionIcon.starForeground": "#0000003e",
    "extensionIcon.verifiedForeground": "#0000003e",
    "focusBorder": "#0000003e",
    "input.background": "#0000003e",
    "input.border": "#0000003e",
    "inputOption.activeBackground": "#0000003e",
    "inputOption.activeBorder": "#0000003e",
    "list.activeSelectionBackground": "#0000003e",
    "list.dropBackground": "#0000003e",
    "list.focusBackground": "#0000003e",
    "list.hoverBackground": "#0000003e",
    "list.inactiveSelectionBackground": "#0000003e",
    "menu.background": "#00000088",
    "menu.border": "#0000003e",
    "menu.foreground": "#ffffffae",
    "menu.separatorBackground": "#0000003e",
    "minimap.background": "#0000003e",
    "minimapSlider.activeBackground": "#0000003e",
    "minimapSlider.background": "#0000003e",
    "minimapSlider.hoverBackground": "#0000003e",
    "notificationCenter.border": "#0000003e",
    "notificationCenterHeader.background": "#0000003e",
    "notificationToast.border": "#0000003e",
    "notifications.background": "#0000003e",
    "notifications.border": "#0000003e",
    "panel.background": "#0000003e",
    "panel.border": "#0000003e",
    "panelInput.border": "#0000003e",
    "panelTitle.activeBorder": "#0000003e",
    "peekViewEditor.background": "#0000003e",
    "peekViewEditorGutter.background": "#0000003e",
    "peekViewResult.background": "#0000003e",
    "peekViewTitle.background": "#0000003e",
    "pickerGroup.border": "#0000003e",
    "progressBar.background": "#0000003e",
    "scrollbar.shadow": "#0000003e",
    "scrollbarSlider.activeBackground": "#0000003e",
    "scrollbarSlider.background": "#0000003e",
    "scrollbarSlider.hoverBackground": "#0000003e",
    "selection.background": "#0000003e",
    "settings.dropdownBackground": "#0000003e",
    "settings.dropdownBorder": "#0000003e",
    "settings.modifiedItemIndicator": "#0000003e",
    "sideBar.background": "#0000003e",
    "sideBar.border": "#0000003e",
    "sideBarSectionHeader.background": "#0000003e",
    "sideBarSectionHeader.border": "#0000003e",
    "statusBar.background": "#0000003e",
    "statusBar.border": "#0000003e",
    "statusBar.debuggingBackground": "#0000003e",
    "statusBar.focusBorder": "#0000003e",
    "statusBar.noFolderBackground": "#0000003e",
    "statusBarItem.activeBackground": "#0000003e",
    "statusBarItem.focusBorder": "#0000003e",
    "statusBarItem.prominentBackground": "#00000030",
    "statusBarItem.remoteBackground": "#00000030",
    "tab.activeBackground": "#00000030",
    "tab.activeBorder": "#0000003e",
    "tab.activeBorderTop": "#0000003e",
    "tab.border": "#0000003e",
    "tab.hoverBackground": "#0000003e",
    "tab.hoverBorder": "#0000003e",
    "tab.inactiveBackground": "#0000003e",
    "tab.inactiveForeground": "#b9b9b95b",
    "tab.unfocusedActiveBorder": "#0000003e",
    "tab.unfocusedActiveBorderTop": "#0000003e",
    "tab.unfocusedHoverBackground": "#0000003e",
    "textBlockQuote.border": "#0000003e",
    "textLink.activeForeground": "#d3d3d3",
    "textLink.foreground": "#ffffffe0",
    "titleBar.activeBackground": "#00000030",
    "titleBar.border": "#0000003e",
    "titleBar.inactiveBackground": "#0000003e",
    "tree.inactiveIndentGuidesStroke": "#0000003e",
    "tree.indentGuidesStroke": "#0000003e",
    "welcomePage.progress.foreground": "#ffffffaa",
    "welcomePage.tileBackground": "#0000003e",
    "welcomePage.tileBorder": "#0000003e",
    "welcomePage.tileHoverBackground": "#0000003e",
    "widget.border": "#0000003e",
    "widget.shadow": "#0000003e"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#ff7171"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Colors",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#0a691b"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#989898"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": [
        "meta.block variable.other"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": [
        "support.other.variable",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#f07178"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.keyword",
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "constant"
      ],
      "settings": {
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "Entity Types",
      "scope": [
        "support.type"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Language methods",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": [
        "entity.name.method.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "CSS Classes",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "CSS ID's",
      "scope": [
        "source.sass keyword.control"
      ],
      "settings": {
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FF5370"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#65737E"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#5f9dff"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#b1c9ff"
      }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": [
        "markup.quote punctuation.definition.blockquote.markdown"
      ],
      "settings": {
        "foreground": "#65737E"
      }
    },
    {
      "name": "Markup - Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Markdown - Link Description",
      "scope": [
        "string.other.link.description.title.markdown"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "Markup - Raw Block",
      "scope": [
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Markdown - Raw Block Fenced",
      "scope": [
        "markup.raw.block.fenced.markdown"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Markdown - Fenced Bode Block",
      "scope": [
        "punctuation.definition.fenced.markdown"
      ],
      "settings": {
        "foreground": "#ffb45e"
      }
    },
    {
      "name": "Markdown - Fenced Bode Block Variable",
      "scope": [
        "markup.raw.block.fenced.markdown",
        "variable.language.fenced.markdown",
        "punctuation.section.class.end"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Markdown - Fenced Language",
      "scope": [
        "variable.language.fenced.markdown"
      ],
      "settings": {
        "foreground": "#65737E"
      }
    },
    {
      "name": "Markdown - Separator",
      "scope": [
        "meta.separator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#65737E"
      }
    },
    {
      "name": "Markup - Table",
      "scope": [
        "markup.table"
      ],
      "settings": {
        "foreground": "#e7e7e7"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "entity.other.attribute-name.class.pug"
      ],
      "settings": {
        "foreground": "#979797"
      }
    }
  ]
}